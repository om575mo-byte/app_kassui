# サーバーポート
PORT=3001

# CORS許可オリジン（本番環境では自ドメインを指定、例: https://your-app.onrender.com）
# 開発時はコメントアウトまたは * を指定
CORS_ORIGIN=*

# OpenWeatherMap APIキー (One Call API 3.0)
# https://openweathermap.org/api/one-call-3 で取得
OPENWEATHERMAP_API_KEY=your_api_key_here

# Pythonコマンド（Docker/Linux: python3、Windows: フルパス指定）
PYTHON_CMD=python3

# データ更新間隔（ミリ秒）
DATA_REFRESH_INTERVAL=600000

# キャッシュ有効期限（秒）
CACHE_TTL=300
